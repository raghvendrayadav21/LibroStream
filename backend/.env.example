# =============================================================
#   SmartLMS - Environment Variables Template
#   
#   INSTRUCTIONS:
#   1. Is file ko copy karo aur naam rakho: .env
#   2. Apni real values daalo neeche
#   3. .env file KABHI GitHub pe upload mat karo!
#      (.gitignore me already added hai)
# =============================================================

# ----- JWT SECRET -----
# Koi bhi random string likho (jitna lamba utna better)
JWT_SECRET=SmartLMS@SuperSecretJWTKey2026ChangeThisNow!

# ----- GMAIL SMTP SETTINGS -----
# Step 1: Gmail account kholo jisse OTP emails bheje jaayenge
# Step 2: myaccount.google.com → Security → 2-Step Verification ON karo
# Step 3: Wahan "App Passwords" milega → New app password generate karo
# Step 4: 16-character code milega jaise: abcd efgh ijkl mnop → woh yahan daalo

MAIL_USERNAME=your-college-library-gmail@gmail.com
MAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ----- MONGODB CONNECTION -----
# Local MongoDB connection (Fallback default):
# MONGODB_URI=mongodb://localhost:27017/smartlms
#
# MongoDB Atlas connection (Replace with your credentials):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/smartlms?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/smartlms
