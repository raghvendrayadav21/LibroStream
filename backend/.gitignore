# =============================================================
#  .gitignore for SmartLMS Backend
# =============================================================

# Maven build output
target/
*.class

# .env files (SECRET - NEVER push to GitHub)
.env
.env.local
.env.production

# IntelliJ IDEA / Eclipse
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/

# VS Code
.vscode/

# Mac OS
.DS_Store

# Logs
*.log
logs/

# Spring Boot packaged jar
*.jar
*.war
